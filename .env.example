# LLM Provider Configuration
# Works with ANY OpenAI-compatible API: OpenRouter, OpenAI, Ollama, LM Studio, Groq, etc.

# API Key (required for cloud providers, optional for local like Ollama)
LLM_API_KEY=your-api-key-here
# Also supported: OPENROUTER_API_KEY, OPENAI_API_KEY

# Base URL - change to your provider
LLM_BASE_URL=https://openrouter.ai/api/v1
# Examples:
#   https://openrouter.ai/api/v1     (default, OpenRouter - 100+ models)
#   https://api.openai.com/v1        (OpenAI direct)
#   http://localhost:11434/v1        (Ollama local)
#   http://localhost:1234/v1          (LM Studio)
#   https://api.groq.com/openai/v1   (Groq)

# Model to use
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# Examples:
#   anthropic/claude-3-5-sonnet-20241022  (OpenRouter)
#   openai/gpt-4o                          (OpenAI)
#   llama-3.1-70b-versatile               (Groq)
#   qwen2.5-coder:32b                     (Ollama)
