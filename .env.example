# LLM Provider Configuration
# Works with any OpenAI-compatible API: OpenRouter, OpenAI, Ollama, LM Studio, Groq, etc.

# API Key (required for cloud providers, optional for local)
OPENROUTER_API_KEY=sk-or-...
# Or use: OPENAI_API_KEY=sk-...

# Base URL (defaults to OpenRouter)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1          # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1           # LM Studio
# OPENAI_BASE_URL=https://api.groq.com/openai/v1      # Groq

# Model (defaults to Claude Sonnet on OpenRouter)
# SYNTHESIZER_MODEL=anthropic/claude-3-5-sonnet-20241022
# SYNTHESIZER_MODEL=openai/gpt-4o
# SYNTHESIZER_MODEL=llama-3.1-70b-versatile          # Groq
# SYNTHESIZER_MODEL=qwen2.5-coder:32b                # Ollama
